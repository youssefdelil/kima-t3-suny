#!/usr/bin/env bash
# bin/delileche — Entry point for delileche youcef — Enhanced macOS Cleanup CLI
# Features: TUI, Heatmap, Profiles, Undo, Smart Scan, HTML Report, JSON output
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LIB_DIR="${SCRIPT_DIR}/../lib"

source "${LIB_DIR}/core/core.sh"
source "${LIB_DIR}/core/utils.sh"
source "${LIB_DIR}/core/preflight.sh"
source "${LIB_DIR}/modules/system/standard.sh"
source "${LIB_DIR}/modules/system/deep.sh"
source "${LIB_DIR}/modules/system/orphans.sh"
source "${LIB_DIR}/modules/system/brew.sh"
source "${LIB_DIR}/modules/system/snapshots.sh"
source "${LIB_DIR}/modules/user/standard.sh"
source "${LIB_DIR}/modules/user/mail.sh"
source "${LIB_DIR}/modules/user/browsers.sh"
source "${LIB_DIR}/modules/user/apps.sh"
source "${LIB_DIR}/modules/dev/devtools.sh"
source "${LIB_DIR}/modules/dev/xcode.sh"
source "${LIB_DIR}/modules/dev/devops.sh"
source "${LIB_DIR}/modules/dev/docker.sh"
source "${LIB_DIR}/optimize/optimize.sh"
source "${LIB_DIR}/tui/tui.sh"
source "${LIB_DIR}/heatmap/heatmap.sh"
source "${LIB_DIR}/profile/profile.sh"
source "${LIB_DIR}/undo/undo.sh"
source "${LIB_DIR}/scan/smart_scan.sh"
source "${LIB_DIR}/report/html_report.sh"

# ── Additional feature flags ───────────────────────────────────────────────────
export USE_TUI=${USE_TUI:-false}
export SHOW_HEATMAP=${SHOW_HEATMAP:-false}
export SHOW_SCAN=${SHOW_SCAN:-false}
export SHOW_UNDO=${SHOW_UNDO:-false}
export HTML_REPORT=${HTML_REPORT:-false}
export PROFILE_NAME=${PROFILE_NAME:-""}
export PROFILE_UI=${PROFILE_UI:-false}

# ── Banner ─────────────────────────────────────────────────────────────────────
_print_banner() {
  [[ ! -t 1 ]] && return
  printf "\n${BOLD}${PURPLE}"
  printf '  ██████╗ ███████╗██╗     ██╗██╗     ███████╗ ██████╗██╗  ██╗███████╗\n'
  printf '  ██╔══██╗██╔════╝██║     ██║██║     ██╔════╝██╔════╝██║  ██║██╔════╝\n'
  printf '  ██║  ██║█████╗  ██║     ██║██║     █████╗  ██║     ███████║█████╗  \n'
  printf '  ██║  ██║██╔══╝  ██║     ██║██║     ██╔══╝  ██║     ██╔══██║██╔══╝  \n'
  printf '  ██████╔╝███████╗███████╗██║███████╗███████╗╚██████╗██║  ██║███████╗\n'
  printf '  ╚═════╝ ╚══════╝╚══════╝╚═╝╚══════╝╚══════╝ ╚═════╝╚═╝  ╚═╝╚══════╝\n'
  printf "${RESET}${DIM}                                    by youcef — v%s${RESET}\n\n" "$VERSION"
}

# ── Help ───────────────────────────────────────────────────────────────────────
show_help() {
  _print_banner
  cat <<EOF
${BOLD}USAGE:${RESET}
  delileche [targets] [options]

${BOLD}INTERACTIVE:${RESET}
  --tui              Launch arrow-key module selector (default if no args given)
  --scan             Smart scan — shows biggest wins with recommendations
  --heatmap          ASCII disk usage heatmap of your top directories
  --profile <name>   Apply a preset: ${CYAN}developer${RESET} | ${CYAN}designer${RESET} | ${CYAN}student${RESET}
  --profile-menu     Interactive profile selector

${BOLD}CLEANUP TARGETS:${RESET}
  --system,  -S      .DS_Store, Trash, crash reports
  --system-deep, -z  Rotated logs, old iOS backups
  --xcode,   -x      DerivedData, Archives, DeviceSupport, Simulator
  --docker,  -d      Docker containers, images, volumes, build cache
  --devtools, -D     node_modules, Rust, Python (.venv/.tox), Gradle, Flutter
  --snapshots, -s    Time Machine local snapshots
  --caches,  -c      ~/Library/Caches, browsers (Arc/Chrome/Firefox/Safari/Brave), apps
  --mail,    -m      Old Mail attachments
  --brew,    -b      brew cleanup + autoremove
  --optimize, -O     DNS flush, LaunchServices rebuild, SQLite vacuum
  --all,     -a      All targets

${BOLD}OPTIONS:${RESET}
  --dry-run,  -n     Preview only — no deletions (default)
  --yes,      -y     Skip confirmation, run live cleanup
  --verbose,  -v     Show per-item details
  --json             Machine-readable JSON summary
  --html             Generate visual HTML report (opens in browser)
  --clean-orphans    Interactively remove orphaned app data (with confidence %)
  --undo             Show what was deleted in last live cleanup
  --devops-reset     Nuclear: all Docker + dev caches
  --include-ml-models  Include HuggingFace/Ollama model caches
  --stats            Show run history
  --show-log         Print operation log
  --version, -V      Print version
  --help,    -h      Show this help

${BOLD}EXAMPLES:${RESET}
  delileche                          Interactive TUI selector
  delileche --scan                   Show biggest disk space wins
  delileche --heatmap                Visual disk usage heatmap
  delileche --profile developer      Dev preset (Xcode, Docker, node_modules)
  delileche --all --dry-run          Preview everything
  delileche --all --yes --html       Full live cleanup + open HTML report
  delileche --xcode --docker --yes   Clean Xcode + Docker, no prompts
  delileche --clean-orphans          Remove orphaned app data interactively
  delileche --undo                   Review last cleanup deletions
  delileche --stats                  Show past run history

${YELLOW}${WARN}  Running without targets launches the TUI selector.${RESET}
EOF
}

show_version() {
  local bar
  bar=$(printf '─%.0s' $(seq 1 40))
  printf "\n${BOLD}${PURPLE}%s${RESET}\n" "$bar"
  printf "${BOLD}${MAGENTA}  delileche v%s${RESET}  ${DIM}by %s${RESET}\n" "$VERSION" "$AUTHOR"
  printf "${BOLD}${PURPLE}%s${RESET}\n\n" "$bar"
}

set_default_targets() {
  TARGET_SYSTEM=true
  TARGET_XCODE=true
  TARGET_DOCKER=true
  TARGET_DEVTOOLS=true
  TARGET_SNAPSHOTS=true
  TARGET_CACHES=true
  TARGET_BREW=true
  TARGET_MAIL=true
  TARGET_SYSTEM_DEEP=true
  TARGET_OPTIMIZE=false
}

has_cleanup_target() {
  [[ "$TARGET_SYSTEM"       == "true" ]] \
    || [[ "$TARGET_XCODE"     == "true" ]] \
    || [[ "$TARGET_DOCKER"    == "true" ]] \
    || [[ "$TARGET_DEVTOOLS"  == "true" ]] \
    || [[ "$TARGET_SNAPSHOTS" == "true" ]] \
    || [[ "$TARGET_CACHES"    == "true" ]] \
    || [[ "$TARGET_BREW"      == "true" ]] \
    || [[ "$TARGET_MAIL"      == "true" ]] \
    || [[ "$TARGET_SYSTEM_DEEP" == "true" ]] \
    || [[ "$TARGET_OPTIMIZE"  == "true" ]] \
    || [[ "$DEVOPS_RESET_MODE" == "true" ]]
}

# ── Flag parsing ───────────────────────────────────────────────────────────────
parse_flags() {
  local target_specified=false
  local explicit_dry_run=false

  if [[ $# -eq 0 ]]; then
    USE_TUI=true
    return
  fi

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --system|-S)         TARGET_SYSTEM=true;       target_specified=true ;;
      --system-deep|-z)    TARGET_SYSTEM_DEEP=true;  target_specified=true ;;
      --xcode|-x)          TARGET_XCODE=true;        target_specified=true ;;
      --docker|-d)         TARGET_DOCKER=true;        target_specified=true ;;
      --devtools|-D)       TARGET_DEVTOOLS=true;      target_specified=true ;;
      --snapshots|-s)      TARGET_SNAPSHOTS=true;     target_specified=true ;;
      --caches|-c)         TARGET_CACHES=true;        target_specified=true ;;
      --mail|-m)           TARGET_MAIL=true;          target_specified=true ;;
      --brew|-b)           TARGET_BREW=true;          target_specified=true ;;
      --optimize|-O)       TARGET_OPTIMIZE=true;      target_specified=true ;;
      --all|-a)
        set_default_targets
        target_specified=true
        ;;
      --tui)               USE_TUI=true ;;
      --scan)              SHOW_SCAN=true ;;
      --heatmap)           SHOW_HEATMAP=true ;;
      --undo)              SHOW_UNDO=true ;;
      --html)              HTML_REPORT=true ;;
      --profile)
        shift
        PROFILE_NAME="${1:-}"
        target_specified=true
        ;;
      --profile-menu)      PROFILE_UI=true ;;
      --clean-orphans)     CLEAN_ORPHANS=true ;;
      --devops-reset)      DEVOPS_RESET_MODE=true ;;
      --include-ml-models) INCLUDE_ML_MODELS=true ;;
      --show-log)          SHOW_OPERATION_LOG=true ;;
      --stats)             SHOW_STATS=true ;;
      --json)              JSON_OUTPUT=true ;;
      --version|-V)        SHOW_VERSION=true ;;
      --dry-run|-n)        DRY_RUN=true; explicit_dry_run=true ;;
      --yes|-y)            SKIP_CONFIRM=true ;;
      --verbose|-v)        VERBOSE=true ;;
      --help|-h)           show_help; exit 0 ;;
      *)
        log::error "Unknown option: $1"
        printf "  Run 'delileche --help' for usage.\n"
        exit 1
        ;;
    esac
    shift
  done

  # Early-exit flags
  if [[ "$SHOW_OPERATION_LOG" == "true" ]] \
    || [[ "$SHOW_VERSION" == "true" ]] \
    || [[ "$SHOW_STATS" == "true" ]] \
    || [[ "$SHOW_UNDO" == "true" ]] \
    || [[ "$SHOW_SCAN" == "true" ]] \
    || [[ "$SHOW_HEATMAP" == "true" ]]; then
    return
  fi

  # Profile
  if [[ -n "$PROFILE_NAME" ]]; then
    profile::apply "$PROFILE_NAME" || exit 1
    return
  fi
  if [[ "$PROFILE_UI" == "true" ]]; then
    profile::show_menu
    return
  fi

  # TUI if no targets
  if ! "$target_specified" 2>/dev/null && ! has_cleanup_target; then
    USE_TUI=true
    return
  fi

  # Live mode logic
  if [[ "$explicit_dry_run" == "true" ]]; then
    DRY_RUN=true
  elif [[ "$SKIP_CONFIRM" == "true" ]]; then
    DRY_RUN=false
  else
    printf '\n%s%s  ⚠  You are about to delete files. This cannot be undone.%s\n' \
      "${BOLD}" "${YELLOW}" "${RESET}"
    printf '   Run with --dry-run first to preview.\n'
    printf '   Continue with live cleanup? [y/N]: '
    local _c
    read -r _c
    if [[ "$_c" =~ ^[Yy]$ ]]; then
      DRY_RUN=false
    else
      log::info "Aborted. Use --dry-run to preview safely."
      exit 0
    fi
  fi
}

# ── Summary report ─────────────────────────────────────────────────────────────
print_report() {
  local duration="$1"
  local disk_before="$2"
  local disk_after="$3"

  local mode_label
  mode_label="$([ "$DRY_RUN" == "true" ] && echo "DRY-RUN" || echo "LIVE")"
  local bar
  bar=$(printf '━%.0s' $(seq 1 72))
  local sep
  sep=$(printf '─%.0s' $(seq 1 72))

  printf '\n%s%s%s%s\n' "${BOLD}" "${PURPLE}" "$bar" "${RESET}"
  printf '%s  🧹 delileche — Summary Report   %s%s%s\n' "${BOLD}" "${DIM}" "by youcef" "${RESET}"
  printf '%s%s%s%s\n' "${BOLD}" "${PURPLE}" "$bar" "${RESET}"
  printf '  Mode: %s%s%s  |  Duration: %ss  |  v%s\n\n' \
    "${CYAN}" "$mode_label" "${RESET}" "$duration" "$VERSION"

  printf '  %s%-18s %-24s %10s %13s   %s%s\n' \
    "${BOLD}" "Category" "Module" "Found" "Reclaimable" "Status" "${RESET}"
  printf '  %s\n' "$sep"

  local total_scanned=0
  local total_projected=0
  local module_count=${#MODULE_NAMES[@]}
  local prev_category=""

  for (( i=0; i<module_count; i++ )); do
    local name="${MODULE_NAMES[$i]}"
    local category="${MODULE_CATEGORIES[$i]}"
    local scanned="${MODULE_SCANNED[$i]}"
    local status="${MODULE_STATUS[$i]}"
    local projected="${MODULE_PROJECTED[$i]:-0}"
    local dur="${MODULE_DURATIONS[$i]:-}"

    total_scanned=$(( total_scanned + scanned ))
    total_projected=$(( total_projected + projected ))

    local cat_display=""
    [[ "$category" != "$prev_category" ]] && cat_display="$category" && prev_category="$category"

    local found_fmt="-"
    (( scanned > 0 )) && found_fmt=$(utils::format_bytes "$scanned")
    local reclaimable_fmt="-"
    (( projected > 0 )) && reclaimable_fmt=$(utils::format_bytes "$projected")
    [[ "$status" == "review" ]] && reclaimable_fmt="0 B"

    local status_str
    case "$status" in
      clean)   status_str="${GREEN}✔ Clean${RESET}" ;;
      skipped) status_str="${YELLOW}Skipped${RESET}" ;;
      review)  status_str="${CYAN}Needs review${RESET}" ;;
      done)    status_str="${GREEN}${CHECK} Done${RESET}" ;;
      pending) status_str="${YELLOW}Pending${RESET}" ;;
      *)       status_str="${DIM}${status}${RESET}" ;;
    esac

    local dur_str=""
    [[ -n "$dur" && "$dur" != "0" ]] && dur_str="  ${DIM}${dur}s${RESET}"

    printf '  %-18s %-24s %10s %13s   %s%s\n' \
      "$cat_display" "$name" "$found_fmt" "$reclaimable_fmt" "$status_str" "$dur_str"
  done

  printf '  %s\n' "$sep"
  printf '  %s%-18s %-24s %10s %13s%s\n' \
    "${BOLD}" "TOTALS" "" \
    "$(utils::format_bytes "$total_scanned")" \
    "$(utils::format_bytes "$total_projected")" "${RESET}"

  printf '\n'
  local free_before_fmt free_after_fmt
  free_before_fmt=$(utils::format_bytes "$disk_before")
  free_after_fmt=$(utils::format_bytes "$disk_after")

  if [[ "$DRY_RUN" == "true" ]]; then
    printf '  %sFree space:%s  %s → %s %s(projected)%s\n' \
      "${BOLD}" "${RESET}" "$free_before_fmt" \
      "$(utils::format_bytes "$(( disk_before + total_projected ))")" "${DIM}" "${RESET}"
  else
    local freed=$(( disk_after - disk_before ))
    [[ $freed -lt 0 ]] && freed=0
    printf '  %sFree space:%s  %s → %s  %s(%s freed)%s\n' \
      "${BOLD}" "${RESET}" "$free_before_fmt" "$free_after_fmt" \
      "${GREEN}" "$(utils::format_bytes "$freed")" "${RESET}"
  fi

  printf '  %sLog:     %s   %s\n' "${BOLD}" "${RESET}" "$LOG_FILE"
  printf '\n  %sLegend:%s  Pending=dry-run queued · Done=cleaned · Skipped=unavailable · review=manual\n' "${BOLD}" "${RESET}"
  printf '%s%s%s%s\n\n' "${BOLD}" "${PURPLE}" "$bar" "${RESET}"
  log::success "Run complete."
}

# ── JSON report ────────────────────────────────────────────────────────────────
print_json_report() {
  local duration="$1"
  local disk_before="$2"
  local disk_after="$3"

  local mode
  mode="$([ "$DRY_RUN" == "true" ] && echo "dry-run" || echo "live")"
  local total_s=0 total_p=0
  local module_count=${#MODULE_NAMES[@]}

  printf '{\n'
  printf '  "tool": "delileche", "version": "%s", "author": "%s",\n' "$VERSION" "$AUTHOR"
  printf '  "timestamp": "%s", "mode": "%s", "duration_seconds": %s,\n' \
    "$(date -u '+%Y-%m-%dT%H:%M:%SZ')" "$mode" "$duration"
  printf '  "disk_free_before_bytes": %s, "disk_free_after_bytes": %s,\n' "$disk_before" "$disk_after"
  printf '  "modules": [\n'

  for (( i=0; i<module_count; i++ )); do
    total_s=$(( total_s + MODULE_SCANNED[$i] ))
    total_p=$(( total_p + MODULE_PROJECTED[$i] ))
    local comma=","
    (( i == module_count - 1 )) && comma=""
    printf '    {"name":"%s","category":"%s","scanned_bytes":%s,"projected_bytes":%s,"status":"%s","duration_seconds":%s}%s\n' \
      "$(json::escape "${MODULE_NAMES[$i]}")" "$(json::escape "${MODULE_CATEGORIES[$i]}")" \
      "${MODULE_SCANNED[$i]}" "${MODULE_PROJECTED[$i]:-0}" \
      "${MODULE_STATUS[$i]}" "${MODULE_DURATIONS[$i]:-0}" "$comma"
  done

  printf '  ],\n'
  printf '  "totals": {"scanned_bytes":%s,"projected_bytes":%s}\n' "$total_s" "$total_p"
  printf '}\n'
}

# ── Main ───────────────────────────────────────────────────────────────────────
main() {
  parse_flags "$@"

  # ── Housekeeping flags ───────────────────────────────────────────────────────
  [[ "$SHOW_VERSION" == "true" ]]       && show_version && exit 0
  [[ "$SHOW_OPERATION_LOG" == "true" ]] && utils::show_operation_log && exit 0
  [[ "$SHOW_STATS" == "true" ]]         && utils::show_stats && exit 0
  [[ "$SHOW_UNDO" == "true" ]]          && undo::show && exit 0

  utils::check_macos
  utils::load_whitelist

  # ── Single-feature modes (no cleanup run) ────────────────────────────────────
  if [[ "$SHOW_SCAN" == "true" ]]; then
    _print_banner
    smart_scan::run
    exit 0
  fi

  if [[ "$SHOW_HEATMAP" == "true" ]]; then
    _print_banner
    heatmap::run
    exit 0
  fi

  # ── Profile menu (sets targets, then falls through to TUI or run) ─────────────
  if [[ "$PROFILE_UI" == "true" ]]; then
    _print_banner
    profile::show_menu
    [[ ! has_cleanup_target ]] && exit 0
  fi

  # ── Interactive TUI ───────────────────────────────────────────────────────────
  if [[ "$USE_TUI" == "true" ]]; then
    if tui::run; then
      # TUI confirmed — apply dry-run by default unless --yes was passed
      [[ "$SKIP_CONFIRM" != "true" ]] && DRY_RUN=true
    else
      exit 0
    fi
  fi

  local start_time
  start_time=$(date +%s)

  # Print system context (non-JSON mode)
  if [[ "$JSON_OUTPUT" != "true" ]]; then
    _print_banner
    profile::describe
    utils::print_system_context
  fi

  # Live mode: pre-flight + warning
  if [[ "$DRY_RUN" != "true" ]]; then
    if [[ "$JSON_OUTPUT" != "true" ]]; then
      printf '\n  %s%s  ⚠  LIVE MODE — files will be permanently deleted%s\n\n' \
        "${BOLD}" "${RED}" "${RESET}"
    fi
    preflight::run
    undo::begin_session
  fi

  local disk_before
  disk_before=$(utils::get_free_bytes)

  run_module() {
    local module_name="$1"
    local module_fn="$2"
    shift 2
    "$module_fn" "$@" || log::warn "Module '${module_name}' encountered an error — continuing."
  }

  # ── System ────────────────────────────────────────────────────────────────────
  [[ "$JSON_OUTPUT" != "true" ]] && log::category "System"
  run_module "System" system::clean
  [[ "$TARGET_SYSTEM_DEEP" == "true" ]] && run_module "System Deep" system_deep::clean
  run_module "Orphans" orphans::clean

  # ── Developer Tools ───────────────────────────────────────────────────────────
  if [[ "$TARGET_XCODE" == "true" || "$TARGET_DOCKER" == "true" || "$TARGET_DEVTOOLS" == "true" ]]; then
    [[ "$JSON_OUTPUT" != "true" ]] && log::category "Developer Tools"
    [[ "$TARGET_XCODE" == "true" ]]    && run_module "Xcode" xcode::clean
    [[ "$TARGET_DOCKER" == "true" ]]   && run_module "Docker" docker::clean
    [[ "$TARGET_DEVTOOLS" == "true" ]] && run_module "Developer Tools" devtools::clean
  fi

  # ── Caches & Logs ─────────────────────────────────────────────────────────────
  if [[ "$TARGET_CACHES" == "true" || "$TARGET_BREW" == "true" || "$TARGET_MAIL" == "true" ]]; then
    [[ "$JSON_OUTPUT" != "true" ]] && log::category "Caches & Logs"
    if [[ "$TARGET_CACHES" == "true" ]]; then
      run_module "Caches" caches::clean
      run_module "Browsers" browsers::clean
      run_module "Apps" apps::clean
    fi
    [[ "$TARGET_MAIL" == "true" ]] && run_module "Mail" mail::clean
    [[ "$TARGET_BREW" == "true" ]] && run_module "Homebrew" brew::clean
  fi

  # ── DevOps Reset ──────────────────────────────────────────────────────────────
  if [[ "$DEVOPS_RESET_MODE" == "true" ]]; then
    [[ "$JSON_OUTPUT" != "true" ]] && log::category "DevOps Reset"
    run_module "DevOps Reset" devops_reset::run
  fi

  # ── Storage Management ────────────────────────────────────────────────────────
  if [[ "$TARGET_SNAPSHOTS" == "true" ]]; then
    [[ "$JSON_OUTPUT" != "true" ]] && log::category "Storage Management"
    run_module "Snapshots" snapshots::clean
  fi

  # ── Optimization ──────────────────────────────────────────────────────────────
  if [[ "${TARGET_OPTIMIZE:-false}" == "true" ]]; then
    [[ "$JSON_OUTPUT" != "true" ]] && log::category "Optimization"
    run_module "Optimize" optimize::run
  fi

  local disk_after
  disk_after=$(utils::get_free_bytes)
  local end_time
  end_time=$(date +%s)
  local duration=$(( end_time - start_time ))

  # Finalize undo record
  [[ "$DRY_RUN" != "true" ]] && undo::finalize_session

  # Save stats
  local freed=$(( disk_after - disk_before ))
  [[ $freed -lt 0 ]] && freed=$TOTAL_FREED
  utils::save_stats "$([ "$DRY_RUN" == "true" ] && echo "dry-run" || echo "live")" \
    "$freed" "$duration" "${#MODULE_NAMES[@]}"

  # ── Output ────────────────────────────────────────────────────────────────────
  if [[ "$JSON_OUTPUT" == "true" ]]; then
    print_json_report "$duration" "$disk_before" "$disk_after"
  else
    print_report "$duration" "$disk_before" "$disk_after"
  fi

  # HTML report
  if [[ "$HTML_REPORT" == "true" ]]; then
    html_report::generate "$duration" "$disk_before" "$disk_after"
  fi
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  main "$@"
fi
