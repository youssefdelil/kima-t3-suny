# ── ASCII Banner ──────────────────────────────────────────────────────────────
_print_banner() {
  if [[ -t 1 ]]; then
    printf "\n${BOLD}${PURPLE}"
    printf '  ██████╗ ███████╗██╗     ██╗██╗     ███████╗ ██████╗██╗  ██╗███████╗\n'
    printf '  ██╔══██╗██╔════╝██║     ██║██║     ██╔════╝██╔════╝██║  ██║██╔════╝\n'
    printf '  ██║  ██║█████╗  ██║     ██║██║     █████╗  ██║     ███████║█████╗  \n'
    printf '  ██║  ██║██╔══╝  ██║     ██║██║     ██╔══╝  ██║     ██╔══██║██╔══╝  \n'
    printf '  ██████╔╝███████╗███████╗██║███████╗███████╗╚██████╗██║  ██║███████╗\n'
    printf '  ╚═════╝ ╚══════╝╚══════╝╚═╝╚══════╝╚══════╝ ╚═════╝╚═╝  ╚═╝╚══════╝\n'
    printf "${RESET}${DIM}                                    by youcef — v%s${RESET}\n\n" "$VERSION"
  fi
}

# ── Help output ────────────────────────────────────────────────────────────────
show_help() {
  _print_banner
  cat <<EOF
${BOLD}USAGE:${RESET}
  delileche [targets] [options]

${BOLD}TARGETS:${RESET}
  --system,  -S       Scan crash reports, .DS_Store, Trash, dev caches
  --system-deep, -z   Deep system cleanup: rotated logs, old diagnostics
  --xcode,   -x       Clean Xcode DerivedData, Archives, iOS DeviceSupport
  --docker,  -d       Clean Docker containers, images, volumes, build cache
  --devtools, -D      Clean node_modules, Rust target/, __pycache__, .venv, .tox, Gradle, Flutter
  --snapshots, -s     Delete local Time Machine snapshots
  --caches,  -c       Clear ~/Library/Caches, Zsh, browser caches, app caches
  --mail,    -m       Clean old Mail downloads and recent-item metadata
  --brew,    -b       Run brew cleanup and autoremove
  --optimize, -O      Run system optimizations (DNS flush, LS rebuild, SQLite vacuum)
  --all,     -a       Run all cleanup targets

${BOLD}OPTIONS:${RESET}
  --dry-run,  -n      Preview what would be deleted (default with no flags)
  --yes,      -y      Skip confirmation prompts and run live cleanup
  --clean-orphans     Interactively remove orphaned app data (with confidence scores)
  --devops-reset      Nuclear cleanup: all Docker assets and developer caches
  --include-ml-models Include HuggingFace/Ollama model caches with --devops-reset
  --json              Output summary report as JSON (stdout)
  --stats             Show history of past runs and exit
  --show-log          Print operation log and exit
  --version,  -V      Print version and exit
  --verbose,  -v      Show detailed per-item output
  --help,     -h      Show this help

${BOLD}EXAMPLES:${RESET}
  delileche                         Preview all cleanups (safe dry-run)
  delileche --all --yes             Clean everything, no prompts
  delileche --xcode --docker        Preview Xcode + Docker cleanup
  delileche --system --dry-run -v   Verbose system-only dry-run
  delileche --all --json            Machine-readable JSON summary
  delileche --devtools               Find orphaned build artifacts
  delileche --devops-reset --yes    Nuclear cleanup of dev toolchain
  delileche --clean-orphans          Interactively remove orphaned app data
  delileche --stats                  Show run history
  delileche --show-log               Show deletion operation log

${YELLOW}${WARN}  No cleanup targets? Defaults to a safe --all --dry-run preview.${RESET}
   Pass targets without --dry-run for Interactive Mode (prompts before deletion).
   Add --yes to skip all prompts and run a live cleanup immediately.

EOF
}

show_version() {
  local bar
  bar=$(printf '─%.0s' $(seq 1 40))
  printf "\n${BOLD}${PURPLE}%s${RESET}\n" "$bar"
  printf "${BOLD}${MAGENTA}  delileche v%s${RESET}  ${DIM}by %s${RESET}\n" "$VERSION" "$AUTHOR"
  printf "${BOLD}${PURPLE}%s${RESET}\n\n" "$bar"
}

set_default_targets() {
  TARGET_SYSTEM=true
  TARGET_XCODE=true
  TARGET_DOCKER=true
  TARGET_DEVTOOLS=true
  TARGET_SNAPSHOTS=true
  TARGET_CACHES=true
  TARGET_BREW=true
  TARGET_MAIL=true
  TARGET_SYSTEM_DEEP=true
  TARGET_OPTIMIZE=false
}

has_cleanup_target() {
  [[ "$TARGET_SYSTEM"      == "true" ]] \
    || [[ "$TARGET_XCODE"     == "true" ]] \
    || [[ "$TARGET_DOCKER"    == "true" ]] \
    || [[ "$TARGET_DEVTOOLS"  == "true" ]] \
    || [[ "$TARGET_SNAPSHOTS" == "true" ]] \
    || [[ "$TARGET_CACHES"    == "true" ]] \
    || [[ "$TARGET_BREW"      == "true" ]] \
    || [[ "$TARGET_MAIL"      == "true" ]] \
    || [[ "$TARGET_SYSTEM_DEEP" == "true" ]] \
    || [[ "$TARGET_OPTIMIZE"  == "true" ]] \
    || [[ "$DEVOPS_RESET_MODE" == "true" ]]
}

# ── Flag parsing ───────────────────────────────────────────────────────────────
parse_flags() {
  if [[ $# -eq 0 ]]; then
    DRY_RUN=true
    set_default_targets
    log::warn "No flags provided. Running --all --dry-run by default."
    return
  fi

  local explicit_dry_run=false
  local target_specified=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --system|-S)        TARGET_SYSTEM=true;       target_specified=true ;;
      --system-deep|-z)   TARGET_SYSTEM_DEEP=true;  target_specified=true ;;
      --xcode|-x)         TARGET_XCODE=true;        target_specified=true ;;
      --docker|-d)        TARGET_DOCKER=true;        target_specified=true ;;
      --devtools|-D)      TARGET_DEVTOOLS=true;      target_specified=true ;;
      --snapshots|-s)     TARGET_SNAPSHOTS=true;     target_specified=true ;;
      --caches|-c)        TARGET_CACHES=true;        target_specified=true ;;
      --mail|-m)          TARGET_MAIL=true;          target_specified=true ;;
      --brew|-b)          TARGET_BREW=true;          target_specified=true ;;
      --optimize|-O)      TARGET_OPTIMIZE=true;      target_specified=true ;;
      --all|-a)
        TARGET_SYSTEM=true
        TARGET_XCODE=true
        TARGET_DOCKER=true
        TARGET_DEVTOOLS=true
        TARGET_SNAPSHOTS=true
        TARGET_CACHES=true
        TARGET_MAIL=true
        TARGET_SYSTEM_DEEP=true
        TARGET_BREW=true
        target_specified=true
        ;;
      --clean-orphans)     CLEAN_ORPHANS=true ;;
      --devops-reset)      DEVOPS_RESET_MODE=true ;;
      --include-ml-models) INCLUDE_ML_MODELS=true ;;
      --show-log)          SHOW_OPERATION_LOG=true ;;
      --stats)             SHOW_STATS=true ;;
      --json)              JSON_OUTPUT=true ;;
      --version|-V)        SHOW_VERSION=true ;;
      --dry-run|-n)        DRY_RUN=true; explicit_dry_run=true ;;
      --yes|-y)            SKIP_CONFIRM=true ;;
      --verbose|-v)        VERBOSE=true ;;
      --help|-h)           show_help; exit 0 ;;
      *)
        log::error "Unknown option: $1"
        printf "  Run 'delileche --help' for usage.\n"
        exit 1
        ;;
    esac
    shift
  done

  if [[ "$SHOW_OPERATION_LOG" == "true" ]] || [[ "$SHOW_VERSION" == "true" ]] || [[ "$SHOW_STATS" == "true" ]]; then
    return
  fi

  if ! has_cleanup_target; then
    set_default_targets
    DRY_RUN=true
    log::warn "No cleanup target selected. Running --all --dry-run by default."
    return
  fi

  if [[ "$explicit_dry_run" == "true" ]]; then
    DRY_RUN=true
  elif [[ "$SKIP_CONFIRM" == "true" ]]; then
    DRY_RUN=false
  else
    printf '\n%s%s  ⚠  You are about to delete files. This cannot be undone.%s\n' \
      "${BOLD}" "${YELLOW}" "${RESET}"
    printf '   Run with --dry-run first to preview what will be removed.\n'
    printf '   Continue with live cleanup? [y/N]: '
    local _confirm
    read -r _confirm
    if [[ "$_confirm" =~ ^[Yy]$ ]]; then
      DRY_RUN=false
    else
      log::info "Aborted. Re-run with --dry-run to preview safely."
      exit 0
    fi
  fi
}

# ── Summary report ─────────────────────────────────────────────────────────────
print_report() {
  local duration="$1"
  local disk_before="$2"
  local disk_after="$3"

  local mode_label
  mode_label="$([ "$DRY_RUN" == "true" ] && echo "DRY-RUN" || echo "LIVE")"

  local bar
  bar=$(printf '━%.0s' $(seq 1 72))
  local sep
  sep=$(printf '─%.0s' $(seq 1 72))

  printf '\n%s%s%s%s\n' "${BOLD}" "${PURPLE}" "$bar" "${RESET}"
  printf '%s  🧹 delileche — Summary Report   %s%s%s\n' "${BOLD}" "${DIM}" "by youcef" "${RESET}"
  printf '%s%s%s%s\n' "${BOLD}" "${PURPLE}" "$bar" "${RESET}"
  printf '  Mode: %s%s%s  |  Duration: %ss  |  v%s\n\n' \
    "${CYAN}" "$mode_label" "${RESET}" "$duration" "$VERSION"

  # Column headers
  printf '  %s%-18s %-24s %10s %13s   %s%s\n' \
    "${BOLD}" "Category" "Module" "Found" "Reclaimable" "Status" "${RESET}"
  printf '  %s\n' "$sep"

  local total_scanned=0
  local total_projected=0
  local module_count=${#MODULE_NAMES[@]}
  local prev_category=""

  if (( module_count == 0 )); then
    printf '  %s(no modules ran)%s\n' "${DIM}" "${RESET}"
  else
    for (( i=0; i<module_count; i++ )); do
      local name="${MODULE_NAMES[$i]}"
      local category="${MODULE_CATEGORIES[$i]}"
      local scanned="${MODULE_SCANNED[$i]}"
      local status="${MODULE_STATUS[$i]}"
      local projected="${MODULE_PROJECTED[$i]:-0}"
      local dur="${MODULE_DURATIONS[$i]:-}"

      total_scanned=$(( total_scanned + scanned ))
      total_projected=$(( total_projected + projected ))

      local cat_display=""
      if [[ "$category" != "$prev_category" ]]; then
        cat_display="$category"
        prev_category="$category"
      fi

      local found_fmt="-"
      (( scanned > 0 )) && found_fmt=$(utils::format_bytes "$scanned")

      local reclaimable_fmt="-"
      (( projected > 0 )) && reclaimable_fmt=$(utils::format_bytes "$projected")
      [[ "$status" == "review" ]] && reclaimable_fmt="0 B"

      local status_str
      case "$status" in
        clean)   status_str="${GREEN}✔ Clean${RESET}" ;;
        skipped) status_str="${YELLOW}Skipped${RESET}" ;;
        review)  status_str="${CYAN}Needs review${RESET}" ;;
        done)    status_str="${GREEN}${CHECK} Done${RESET}" ;;
        pending) status_str="${YELLOW}Pending${RESET}" ;;
        *)       status_str="${DIM}${status}${RESET}" ;;
      esac

      local dur_str=""
      [[ -n "$dur" && "$dur" != "0" ]] && dur_str="  ${DIM}${dur}s${RESET}"

      printf '  %-18s %-24s %10s %13s   %s%s\n' \
        "$cat_display" "$name" "$found_fmt" "$reclaimable_fmt" "$status_str" "$dur_str"
    done
  fi

  printf '  %s\n' "$sep"
  local total_found_fmt total_reclaimable_fmt
  total_found_fmt=$(utils::format_bytes "$total_scanned")
  total_reclaimable_fmt=$(utils::format_bytes "$total_projected")

  printf '  %s%-18s %-24s %10s %13s%s\n' \
    "${BOLD}" "TOTALS" "" "$total_found_fmt" "$total_reclaimable_fmt" "${RESET}"

  printf '\n'
  local free_before_fmt free_after_fmt
  free_before_fmt=$(utils::format_bytes "$disk_before")
  free_after_fmt=$(utils::format_bytes "$disk_after")

  if [[ "$DRY_RUN" == "true" ]]; then
    local projected_total=$(( disk_before + total_projected ))
    local projected_fmt
    projected_fmt=$(utils::format_bytes "$projected_total")
    printf '  %sFree space:%s  %s → %s %s(projected)%s\n' \
      "${BOLD}" "${RESET}" "$free_before_fmt" "$projected_fmt" "${DIM}" "${RESET}"
  else
    local actual_freed=$(( disk_after - disk_before ))
    [[ $actual_freed -lt 0 ]] && actual_freed=0
    printf '  %sFree space:%s  %s → %s  %s(%s freed)%s\n' \
      "${BOLD}" "${RESET}" "$free_before_fmt" "$free_after_fmt" \
      "${GREEN}" "$(utils::format_bytes "$actual_freed")" "${RESET}"
  fi

  printf '  %sLog saved:%s   %s\n' "${BOLD}" "${RESET}" "$LOG_FILE"
  printf '\n  %sStatus legend:%s\n' "${BOLD}" "${RESET}"
  if [[ "$DRY_RUN" == "true" ]]; then
    printf '  • Pending: items queued for deletion in a live run\n'
    printf '  • ✔ Clean: module found nothing to delete\n'
  else
    printf '  • ✔ Done: module cleaned successfully\n'
    printf '  • ✔ Clean: module was already clean\n'
  fi
  printf '  • Needs review: manual action required (e.g. --clean-orphans)\n'
  printf '  • Skipped: prerequisite unavailable (e.g. brew, docker not installed)\n'
  printf '%s%s%s%s\n\n' "${BOLD}" "${PURPLE}" "$bar" "${RESET}"
  log::success "Run complete."
}

# ── JSON summary ───────────────────────────────────────────────────────────────
print_json_report() {
  local duration="$1"
  local disk_before="$2"
  local disk_after="$3"

  local mode
  mode="$([ "$DRY_RUN" == "true" ] && echo "dry-run" || echo "live")"

  local total_scanned=0
  local total_projected=0
  local module_count=${#MODULE_NAMES[@]}

  printf '{\n'
  printf '  "tool": "delileche",\n'
  printf '  "version": "%s",\n' "$VERSION"
  printf '  "author": "%s",\n' "$AUTHOR"
  printf '  "timestamp": "%s",\n' "$(date -u '+%Y-%m-%dT%H:%M:%SZ')"
  printf '  "mode": "%s",\n' "$mode"
  printf '  "duration_seconds": %s,\n' "$duration"
  printf '  "disk_free_before_bytes": %s,\n' "$disk_before"
  printf '  "disk_free_after_bytes": %s,\n' "$disk_after"
  printf '  "modules": [\n'

  for (( i=0; i<module_count; i++ )); do
    total_scanned=$(( total_scanned + MODULE_SCANNED[$i] ))
    total_projected=$(( total_projected + MODULE_PROJECTED[$i] ))
    local comma=","
    (( i == module_count - 1 )) && comma=""
    printf '    {\n'
    printf '      "name": "%s",\n' "$(json::escape "${MODULE_NAMES[$i]}")"
    printf '      "category": "%s",\n' "$(json::escape "${MODULE_CATEGORIES[$i]}")"
    printf '      "scanned_bytes": %s,\n' "${MODULE_SCANNED[$i]}"
    printf '      "projected_bytes": %s,\n' "${MODULE_PROJECTED[$i]:-0}"
    printf '      "status": "%s",\n' "${MODULE_STATUS[$i]}"
    printf '      "duration_seconds": %s\n' "${MODULE_DURATIONS[$i]:-0}"
    printf '    }%s\n' "$comma"
  done

  printf '  ],\n'
  printf '  "totals": {\n'
  printf '    "scanned_bytes": %s,\n' "$total_scanned"
  printf '    "projected_bytes": %s\n' "$total_projected"
  printf '  }\n'
  printf '}\n'
}

# ── Main ───────────────────────────────────────────────────────────────────────
main() {
  parse_flags "$@"

  if [[ "$SHOW_VERSION" == "true" ]]; then
    show_version
    exit 0
  fi

  if [[ "$SHOW_OPERATION_LOG" == "true" ]]; then
    utils::show_operation_log
    exit 0
  fi

  if [[ "$SHOW_STATS" == "true" ]]; then
    utils::show_stats
    exit 0
  fi

  utils::check_macos
  utils::load_whitelist

  local start_time
  start_time=$(date +%s)

  if [[ "$JSON_OUTPUT" != "true" ]]; then
    _print_banner
    utils::print_system_context
  fi

  # Live mode: pre-flight + warning
  if [[ "$DRY_RUN" != "true" ]]; then
    if [[ "$JSON_OUTPUT" != "true" ]]; then
      printf '\n  %s%s  ⚠  LIVE MODE — files will be permanently deleted%s\n\n' \
        "${BOLD}" "${RED}" "${RESET}"
    fi
    preflight::run
  fi

  local disk_before
  disk_before=$(utils::get_free_bytes)

  run_module() {
    local module_name="$1"
    local module_fn="$2"
    shift 2
    if ! "$module_fn" "$@"; then
      log::warn "Module '${module_name}' encountered an error — continuing."
    fi
  }

  # ── System ────────────────────────────────────────────────────────────────
  [[ "$JSON_OUTPUT" != "true" ]] && log::category "System"
  run_module "System" system::clean
  [[ "$TARGET_SYSTEM_DEEP" == "true" ]] && run_module "System Deep" system_deep::clean
  run_module "Orphans" orphans::clean

  # ── Developer Tools ───────────────────────────────────────────────────────
  if [[ "$TARGET_XCODE" == "true" ]] || [[ "$TARGET_DOCKER" == "true" ]] || [[ "$TARGET_DEVTOOLS" == "true" ]]; then
    [[ "$JSON_OUTPUT" != "true" ]] && log::category "Developer Tools"
    [[ "$TARGET_XCODE" == "true" ]]    && run_module "Xcode" xcode::clean
    [[ "$TARGET_DOCKER" == "true" ]]   && run_module "Docker" docker::clean
    [[ "$TARGET_DEVTOOLS" == "true" ]] && run_module "Developer Tools" devtools::clean
  fi

  # ── Caches & Logs ─────────────────────────────────────────────────────────
  if [[ "$TARGET_CACHES" == "true" ]] || [[ "$TARGET_BREW" == "true" ]] || [[ "$TARGET_MAIL" == "true" ]]; then
    [[ "$JSON_OUTPUT" != "true" ]] && log::category "Caches & Logs"
    if [[ "$TARGET_CACHES" == "true" ]]; then
      run_module "Caches" caches::clean
      run_module "Browsers" browsers::clean
      run_module "Apps" apps::clean
    fi
    [[ "$TARGET_MAIL" == "true" ]] && run_module "Mail" mail::clean
    [[ "$TARGET_BREW" == "true" ]] && run_module "Homebrew" brew::clean
  fi

  # ── DevOps Reset ─────────────────────────────────────────────────────────
  if [[ "$DEVOPS_RESET_MODE" == "true" ]]; then
    [[ "$JSON_OUTPUT" != "true" ]] && log::category "Developer Tools"
    run_module "DevOps Reset" devops_reset::run
  fi

  # ── Storage Management ────────────────────────────────────────────────────
  if [[ "$TARGET_SNAPSHOTS" == "true" ]]; then
    [[ "$JSON_OUTPUT" != "true" ]] && log::category "Storage Management"
    run_module "Snapshots" snapshots::clean
  fi

  # ── Optimization ─────────────────────────────────────────────────────────
  if [[ "${TARGET_OPTIMIZE:-false}" == "true" ]]; then
    [[ "$JSON_OUTPUT" != "true" ]] && log::category "Optimization"
    run_module "Optimize" optimize::run
  fi

  local disk_after
  disk_after=$(utils::get_free_bytes)

  local end_time
  end_time=$(date +%s)
  local duration=$(( end_time - start_time ))

  # Save stats
  local freed_bytes=$(( disk_after - disk_before ))
  [[ $freed_bytes -lt 0 ]] && freed_bytes=$TOTAL_FREED
  utils::save_stats "$([ "$DRY_RUN" == "true" ] && echo "dry-run" || echo "live")" \
    "$freed_bytes" "$duration" "${#MODULE_NAMES[@]}"

  # Output
  if [[ "$JSON_OUTPUT" == "true" ]]; then
    print_json_report "$duration" "$disk_before" "$disk_after"
  else
    print_report "$duration" "$disk_before" "$disk_after"
  fi
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  main "$@"
fi
